datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  userId         BigInt     @id @default(autoincrement()) @map("user_id")
  firstName      String     @map("first_name") @db.VarChar(100)
  lastName       String?    @map("last_name") @db.VarChar(100)
  emailId        String?    @unique @map("email_id") @db.VarChar(254)
  mobileNo       String?    @map("mobile_no") @db.VarChar(12)
  password       String     @db.VarChar(100) // Extended limit for bcrypt hashes
  addedBy        BigInt?    @map("added_by")
  addedDate      DateTime   @default(now()) @map("added_date") @db.Timestamptz
  profilePicPath String     @default("") @map("profile_pic_path") @db.Text
  lastActiveTime DateTime?  @map("last_active_time") @db.Timestamptz

  // Self relations
  creator        User?      @relation("UserToUser", fields: [addedBy], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  createdUsers   User[]     @relation("UserToUser")

  // Relations to other tables
  addedCompanies   Company[] @relation("CompanyAddedBy")
  updatedCompanies Company[] @relation("CompanyUpdatedBy")
  addedCatalogues   Catalogue[] @relation("CatalogueAddedBy")
  updatedCatalogues Catalogue[] @relation("CatalogueUpdatedBy")
  addedProducts     Product[]   @relation("ProductAddedBy")
  updatedProducts   Product[]   @relation("ProductUpdatedBy")

  @@map("users")
}

model Company {
  companyId    BigInt     @id @default(autoincrement()) @map("company_id")
  companyName  String     @map("company_name") @db.VarChar(250)
  address      String?    @db.Text
  pincode      String?    @db.VarChar(10)
  logoImgPath  String?    @map("logo_img_path") @db.Text
  addedBy      BigInt?    @unique @map("added_by")
  addedDate    DateTime   @default(now()) @map("added_date") @db.Timestamptz
  updatedBy    BigInt?    @map("updated_by")
  updatedDate  DateTime?  @map("updated_date") @db.Timestamptz
  supportEmail String?    @map("support_email") @db.VarChar(254)
  supportPhone String?    @map("support_phone") @db.VarChar(15)
  salesEmail   String?    @map("sales_email") @db.VarChar(254)
  salesPhone   String?    @map("sales_phone") @db.VarChar(15)

  // Relations
  addedByUser   User?     @relation("CompanyAddedBy", fields: [addedBy], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  updatedByUser User?     @relation("CompanyUpdatedBy", fields: [updatedBy], references: [userId], onDelete: SetNull, onUpdate: Cascade)

  socialMediaMappers CompanySocialMediaMapper[]
  catalogues         Catalogue[]
  products           Product[]
  orders             Order[]
  subscription       Subscription?

  @@map("company")
}

model CompanySocialMediaMapper {
  companySocialMediaMapperId BigInt @id @default(autoincrement()) @map("company_social_media_mapper_id")
  companyId                  BigInt @map("company_id")
  socialMediaId              BigInt @map("social_media_id")
  socialMedia                String @map("social_media") @db.Text

  // Relations
  company           Company           @relation(fields: [companyId], references: [companyId], onDelete: Cascade, onUpdate: Cascade)
  socialMediaMaster SocialMediaMaster @relation(fields: [socialMediaId], references: [socialMediaId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([companyId, socialMediaId])
  @@map("company_social_media_mapper")
}

model SocialMediaMaster {
  socialMediaId BigInt @id @default(autoincrement()) @map("social_media_id")
  socialMedia   String @map("social_media") @db.VarChar(50)

  mappers CompanySocialMediaMapper[]

  @@map("social_media_master")
}

model Catalogue {
  catalogueId BigInt    @id @default(autoincrement()) @map("catalogue_id")
  catalogue   String?   @db.VarChar(250)
  companyId   BigInt    @map("company_id")
  addedBy     BigInt    @map("added_by")
  addedDate   DateTime  @default(now()) @map("added_date") @db.Timestamptz
  updatedBy   BigInt?   @map("updated_by")
  updatedDate DateTime? @map("updated_date") @db.Timestamptz
  isDeleted   Boolean   @default(false) @map("is_deleted")
  slug        String?   @db.VarChar(250)
  isPublished Boolean   @default(false) @map("is_published")

  // Relations
  company       Company @relation(fields: [companyId], references: [companyId], onDelete: Cascade, onUpdate: Cascade)
  addedByUser   User    @relation("CatalogueAddedBy", fields: [addedBy], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  updatedByUser User?   @relation("CatalogueUpdatedBy", fields: [updatedBy], references: [userId], onDelete: SetNull, onUpdate: Cascade)

  products Product[]

  @@map("catalogues")
}

model Product {
  productId       BigInt    @id @default(autoincrement()) @map("product_id")
  product         String    @db.VarChar(150)
  sku             String?   @unique @db.VarChar(50)
  description     String?   @db.Text
  price           Decimal?  @db.Decimal(12, 2)
  priceMode       String?   @default("perPiece") @map("price_mode") @db.VarChar(10)
  setQuantity     Decimal?  @map("set_quantity") @db.Decimal(10, 4)
  meterQuantity   Decimal?  @map("meter_quantity") @db.Decimal(10, 4)
  setName         String?   @map("set_name") @db.VarChar(100)
  minimumOrderQty Int?      @map("minimum_order_qty")
  companyId       BigInt    @map("company_id")
  addedBy         BigInt?   @map("added_by")
  addedDate       DateTime  @default(now()) @map("added_date") @db.Timestamptz
  updatedBy       BigInt?   @map("updated_by")
  updatedDate     DateTime? @map("updated_date") @db.Timestamptz
  slug            String?   @db.Text
  isDeleted       Boolean   @default(false) @map("is_deleted")
  catalogueId     BigInt    @map("catalogue_id")

  // Relations
  company       Company   @relation(fields: [companyId], references: [companyId], onDelete: Cascade, onUpdate: Cascade)
  addedByUser   User?     @relation("ProductAddedBy", fields: [addedBy], references: [userId], onDelete: SetNull, onUpdate: Cascade)
  updatedByUser User?     @relation("ProductUpdatedBy", fields: [updatedBy], references: [userId], onDelete: SetNull, onUpdate: Cascade)
  catalogue     Catalogue @relation(fields: [catalogueId], references: [catalogueId])

  images         ProductImage[]
  bulkDiscounts  ProductBulkDiscountSlab[]
  variantOptions ProductVariantOption[]
  orderItems     OrderItem[]

  @@map("products")
}

model ProductImage {
  productImgId   BigInt @id @default(autoincrement()) @map("product_img_id")
  productImgPath String @map("product_img_path") @db.Text
  productId      BigInt @map("product_id")

  // Relations
  product Product @relation(fields: [productId], references: [productId], onDelete: Cascade, onUpdate: Cascade)

  @@map("product_images")
}

model ProductBulkDiscountSlab {
  slabId          BigInt   @id @default(autoincrement()) @map("slab_id")
  productId       BigInt   @map("product_id")
  minQty          Int      @map("min_qty")
  maxQty          Int?     @map("max_qty")
  discountedPrice Decimal? @map("discounted_price") @db.Decimal(12, 2)
  discountPercent Decimal? @map("discount_percent") @db.Decimal(5, 2)
  sortOrder       Int      @default(0) @map("sort_order")

  // Relations
  product Product @relation(fields: [productId], references: [productId], onDelete: Cascade, onUpdate: Cascade)

  @@map("product_bulk_discount_slabs")
}

model ProductVariantOption {
  optionId   BigInt  @id @default(autoincrement()) @map("option_id")
  productId  BigInt  @map("product_id")
  optionType String  @map("option_type") @db.VarChar(20) // "size" or "color"
  label      String  @db.VarChar(100)
  accent     String? @db.VarChar(20)
  sortOrder  Int     @default(0) @map("sort_order")

  // Relations
  product Product @relation(fields: [productId], references: [productId], onDelete: Cascade, onUpdate: Cascade)

  inventories ProductVariantInventory[]

  @@map("product_variant_options")
}

model ProductVariantInventory {
  inventoryId BigInt @id @default(autoincrement()) @map("inventory_id")
  productId   BigInt @map("product_id")
  optionId    BigInt @map("option_id")
  quantity    Int    @default(0)

  option ProductVariantOption @relation(fields: [optionId], references: [optionId], onDelete: Cascade, onUpdate: Cascade)

  @@map("product_variant_inventories")
}

model Order {
  orderId         BigInt      @id @default(autoincrement()) @map("order_id")
  customerName    String      @map("customer_name") @db.VarChar(255)
  customerPhone   String      @map("customer_phone") @db.VarChar(20)
  customerAddress String      @map("customer_address") @db.Text
  status          String      @default("UNCONFIRMED") @db.VarChar(20) // "UNCONFIRMED", "CONFIRMED", etc.
  subtotal        Decimal     @db.Decimal(12, 2)
  discount        Decimal     @default(0) @db.Decimal(12, 2)
  shipping        Decimal     @default(0) @db.Decimal(12, 2)
  total           Decimal     @db.Decimal(12, 2)
  addedDate       DateTime    @default(now()) @map("added_date") @db.Timestamptz
  companyId       BigInt      @map("company_id")

  company         Company     @relation(fields: [companyId], references: [companyId], onDelete: Cascade)
  items           OrderItem[]

  @@map("orders")
}

model OrderItem {
  itemId            BigInt   @id @default(autoincrement()) @map("item_id")
  orderId           BigInt   @map("order_id")
  productId         BigInt   @map("product_id")
  title             String   @db.VarChar(150)
  sku               String?  @db.VarChar(50)
  qty               Int
  price             Decimal  @db.Decimal(12, 2)
  deletedByCustomer Boolean  @default(false) @map("deleted_by_customer")

  order             Order    @relation(fields: [orderId], references: [orderId], onDelete: Cascade)
  product           Product  @relation(fields: [productId], references: [productId])

  @@map("order_items")
}

model Subscription {
  subscriptionId BigInt    @id @default(autoincrement()) @map("subscription_id")
  companyId      BigInt    @unique @map("company_id")
  planName       String    @default("FREE") @map("plan_name") @db.VarChar(50)
  startDate      DateTime  @default(now()) @map("start_date") @db.Timestamptz
  endDate        DateTime? @map("end_date") @db.Timestamptz
  status         String    @default("ACTIVE") @db.VarChar(20)
  pricePaid      Decimal   @default(0) @map("price_paid") @db.Decimal(10, 2)
  updatedDate    DateTime? @map("updated_date") @db.Timestamptz

  company        Company   @relation(fields: [companyId], references: [companyId], onDelete: Cascade)

  @@map("subscriptions")
}
