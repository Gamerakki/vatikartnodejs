# Server Config
PORT=8080
NODE_ENV=development

# Database Configuration
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

DEFAULT_DB_HOST=localhost
DEFAULT_DB_USER=postgres
DEFAULT_DB_PASS=password
DEFAULT_DB_NAME=vatikart_db
DEFAULT_DB_PORT=5432
DEFAULT_DB_SSL_MODE=disable
DEFAULT_DB_TIMEZONE=Asia/Kolkata

# Redis Configuration
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# Security / Token
JWT_SECRET=changeme_super_secret_key
TOKEN_HOUR_LIFESPAN=24

# Static files / uploads
STATIC_FILE_DIR=/public

# CORS Configurations
ALLOWED_ORIGINS=http://localhost:3000
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
ALLOWED_HEADERS=Content-Type,Authorization
EXPOSE_HEADERS=Content-Length,Authorization
ALLOW_CREDENTIALS=true

# S3 / Cloudflare R2 configurations
BUCKET=vatikart-bucket
ACCESS_KEY_ID=your_access_key_id
SECRET_ACCESS_KEY=your_secret_access_key
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
PUBLIC_BUCKET_URL=https://s3.amazonaws.com/your-bucket

# Brevo Mail API configurations
BREVO_API_KEY=your_brevo_api_key
BREVO_MAIL_SENDER_NAME="Vatikart"
BREVO_MAIL_SENDER_EMAIL=info@vatikart.com
